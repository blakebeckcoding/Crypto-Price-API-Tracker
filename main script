import requests
import tkinter as tk
from datetime import datetime

def trackBitcoin():
    try:
        url = "enter any crypto API you want"
        response = requests.get(url, timeout=5).json()
        price = float(response["price"])
        time = datetime.now().strftime("%H:%M:%S")
        labelPrice.config(text=f"{price:,.2f} $")
        labelTime.config(text="Updated at: " + time)
    except Exception:
        labelPrice.config(text="Getting price/Doesn't have an API connected")
        labelTime.config(text="Retrying in 30s...")
    canvas.after(30000, trackBitcoin)

canvas = tk.Tk()
canvas.geometry("700x700")
canvas.title("Blakes Crypto Price Tracker")

f1 = ("poppins", 24, "bold")
f2 = ("poppins", 22, "bold")
f3 = ("poppins", 18, "normal")

label = tk.Label(canvas, text="Crypto Price", font=f1)
label.pack(pady=20)

labelPrice = tk.Label(canvas, font=f2)
labelPrice.pack(pady=20)

labelTime = tk.Label(canvas, font=f3)
labelTime.pack(pady=20)

trackBitcoin()
canvas.mainloop()
